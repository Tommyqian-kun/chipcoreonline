# 测试环境配置模板
# 复制此文件为 .env.test 并填入实际值

# Application
PORT=8080
FRONTEND_URL=http://localhost:3000
NODE_ENV=test

# Cookie & Session Security
COOKIE_SECRET=YOUR_COOKIE_SECRET_HERE

# Database & Redis (测试环境)
DATABASE_URL=postgresql://test:test@localhost:5433/logiccore_test
REDIS_URL=redis://localhost:6380/0

# Database Connection Pool Configuration
DB_CONNECTION_LIMIT=30
DB_POOL_TIMEOUT=30
DB_CONNECT_TIMEOUT=10000
DB_QUERY_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000

# Python SQLAlchemy连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_PY=30
DB_POOL_RECYCLE=3600

# Redis Connection Pool Configuration
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=100
REDIS_KEEP_ALIVE=30000
REDIS_ENABLE_OFFLINE_QUEUE=false
REDIS_MAX_LOADING_TIMEOUT=5000

# Security (测试环境密钥)
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=1d

# Email Configuration (测试环境)
EMAIL_HOST=smtp.126.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email@126.com
EMAIL_PASS=your_email_password
EMAIL_FROM=your_email@126.com

# Alipay Configuration (测试环境沙箱配置)
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_APP_PRIVATE_KEY_PATH=alipay_sandbox_private_traditional.pem
ALIPAY_PUBLIC_KEY_PATH=alipay_sandbox_public_traditional.pem
ALIPAY_NOTIFY_URL=http://localhost:8080/api/v1/payment/notify/alipay

# WeChat Pay Configuration (测试环境)
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_CERTIFICATE_SERIAL_NO=your_serial_no
WECHAT_API_V3_KEY=your_wechat_api_v3_key
WECHAT_NOTIFY_URL=http://localhost:8080/api/v1/payment/notify/wechat
API_BASE_URL=http://localhost:8080

# 阿里云配置 (测试环境)
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_RAM_ROLE_ARN=acs:ram::test:role/test-role
ALIYUN_STS_REGION=cn-hangzhou

# OSS配置 (测试环境)
OSS_REGION=cn-hangzhou
OSS_BUCKET_USER_INPUT=test-user-input-bucket
OSS_BUCKET_JOB_RESULTS=test-job-results-bucket
OSS_BUCKET_JOB_LOGS=test-job-logs-bucket

# Python Worker Configuration
PYTHON_PATH=/home/tommy2025/work/LogicCore/venv/bin/python3
ECS_TOTAL_CPU=16
ECS_TOTAL_MEMORY_GB=64
JOB_CPU_REQUEST=1
JOB_MEMORY_REQUEST_GB=2
WORKER_ID=worker-test-01
ECS_INSTANCE_ID=ecs-test-instance
TASK_QUEUE_NAME=task_queue

# 临时目录配置（测试环境）
TEMP_UPLOAD_DIR="/home/tommy2025/work/LogicCore/temp/test"
TASK_LOGS_DIR="/home/tommy2025/work/LogicCore/logs/test"

# ========================================
# ECS Only 部署模式配置（测试环境）
# ========================================
DEPLOYMENT_MODE="ecs_only"

ECS_LOCAL_STORAGE_ROOT="/home/tommy2025/work/LogicCore"
ECS_JOBS_DIR="/home/tommy2025/work/LogicCore/jobs/test"
ECS_TEMPLATES_DIR="/home/tommy2025/work/LogicCore/templates"
ECS_DOCKER_DIR="/home/tommy2025/work/LogicCore/docker"
ECS_TEMP_CLEANUP_INTERVAL="120"
ECS_MAX_STORAGE_SIZE="50GB"
ECS_FILE_DOWNLOAD_PORT="8081"
ECS_DOWNLOAD_TIMEOUT="120"
ECS_FAILED_TASK_CLEANUP_DELAY="300"
ECS_LOG_RETENTION_HOURS="24"

# 镜像缓存配置
LOCAL_DOCKER_REGISTRY_ENABLED="true"
LOCAL_IMAGES_CACHE_SIZE="20GB"

# ========================================
# 任务队列配置（测试环境）
# ========================================
MAX_QUEUE_LENGTH=48
QUEUE_WAIT_TIMEOUT_MINUTES=35
CONTAINER_EXECUTION_TIMEOUT_MINUTES=3

# ========================================
# Worker配置（测试环境）
# ========================================
WORKER_COUNT=4
MAX_CONCURRENT_PER_WORKER=4
MAX_CONCURRENT_TASKS=16

# ========================================
# 清理配置（测试环境）
# ========================================
CLEANUP_INTERVAL_MINUTES=60
HEALTH_CHECK_INTERVAL_MINUTES=5

BACKUP_LOCAL_DIR="/home/tommy2025/work/LogicCore/tmp/backups/test"

TOOL_PAGE_METHOD=multi
