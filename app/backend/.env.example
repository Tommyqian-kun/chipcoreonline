# 数据库连接
DATABASE_URL="postgresql://username:password@localhost:5432/chip_tools_db"

# JWT 密钥（生产环境请使用强密钥）
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Redis 连接
REDIS_URL="redis://localhost:6379"

# 阿里云 OSS 配置（可选，用于文件存储）
OSS_REGION="oss-cn-hangzhou"
OSS_ACCESS_KEY_ID="your-access-key-id"
OSS_ACCESS_KEY_SECRET="your-access-key-secret"
OSS_BUCKET="your-bucket-name"

# 支付配置（可选）
ALIPAY_APP_ID="your-alipay-app-id"
ALIPAY_PRIVATE_KEY="your-alipay-private-key"
WECHAT_APP_ID="your-wechat-app-id"
WECHAT_APP_SECRET="your-wechat-app-secret"

# 开发环境配置
NODE_ENV="development"
PORT="5000"

# 工具页面模式配置
# 控制SDC工具页面交互模式：
# - single: 使用单页面交互模式
# - multi: 使用多页面交互模式（默认）
TOOL_PAGE_METHOD="multi"

# 模板文件路径配置
# 开发环境：留空使用默认路径 (项目目录/stuff/tool_template)
# 生产环境：设置为ECS上的模板目录路径，如 /data/templates 或 /opt/chipcore/templates
TEMPLATE_ROOT_PATH=""

# 临时上传目录配置 - 重要：用于存储任务上传文件
# 注意：此目录不能放在系统/tmp下，因为可能被系统清理
# 应该与app目录平行，确保数据安全和跨平台一致性
# 开发环境示例：E:\project\LogicCore\temp (Windows) 或 /data/logiccore/temp (Linux)
# 生产环境示例：/data/chipcore/temp
TEMP_UPLOAD_DIR=""

# 备份目录配置 - 用于存储数据库和系统备份文件
# 注意：此目录应该在项目目录内，确保备份文件的安全性
# 开发环境示例：E:\project\LogicCore\backups (Windows) 或 /data/logiccore/backups (Linux)
# 生产环境示例：/data/chipcore/backups
BACKUP_LOCAL_DIR=""

# ========================================
# ECS Only 部署模式配置
# ========================================

# 部署模式控制（默认为ECS Only模式）
# 可选值: ecs_only | ecs_oss_acr
DEPLOYMENT_MODE="ecs_only"

# ECS Only模式专用配置（生产环境目录结构）
ECS_LOCAL_STORAGE_ROOT="/data/chipcore"
ECS_JOBS_DIR="/data/chipcore/jobs"
ECS_TEMPLATES_DIR="/data/chipcore/templates"
ECS_DOCKER_DIR="/data/chipcore/docker"
ECS_TEMP_CLEANUP_INTERVAL="120"  # 2分钟清理间隔(秒)
ECS_MAX_STORAGE_SIZE="50GB"      # 最大本地存储限制
ECS_FILE_DOWNLOAD_PORT="8081"    # 文件下载服务端口
ECS_DOWNLOAD_TIMEOUT="120"       # 下载超时时间(秒)
ECS_FAILED_TASK_CLEANUP_DELAY="300"  # 失败任务jobs目录清理延迟(秒)，默认5分钟
ECS_LOG_RETENTION_HOURS="24"          # 日志目录保留时间(小时)，默认24小时

# 镜像缓存配置
LOCAL_DOCKER_REGISTRY_ENABLED="true"
LOCAL_IMAGES_CACHE_SIZE="20GB"